<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/word_study_book_card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 词书标题和修改按钮 -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_book_icon"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="📘"
                    android:textSize="24sp"
                    android:gravity="center"
                    android:layout_marginEnd="8dp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_book_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="四级词汇"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurface" />

                    <TextView
                        android:id="@+id/tv_book_tag"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="四级 · 共3000词"
                        android:textSize="14sp"
                        android:textColor="?attr/colorOnSurfaceVariant" />
                </LinearLayout>
            </LinearLayout>

            <Button
                android:id="@+id/btn_modify_book"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="修改 >"
                android:textSize="14sp" />
        </RelativeLayout>

        <!-- 进度条 -->
        <ProgressBar
            android:id="@+id/progress_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:layout_marginBottom="8dp"
            android:progress="42"
            android:max="100"
            android:progressTint="?attr/colorPrimary" />

        <TextView
            android:id="@+id/tv_progress_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="已完成 1,250 / 3,000 词"
            android:textSize="14sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginBottom="16dp" />

        <!-- 今日计划 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/colorOutline"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="─── 今日计划 ───"
            android:textSize="12sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/tv_new_cards"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="新词 15"
                android:textSize="16sp"
                android:textColor="?attr/colorOnSurface" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  ·  "
                android:textSize="16sp"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <TextView
                android:id="@+id/tv_review_cards"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="复习 45"
                android:textSize="16sp"
                android:textColor="?attr/colorOnSurface" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_estimated_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="预计用时 25 分钟"
            android:textSize="14sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginBottom="16dp" />

        <!-- 开始学习按钮 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_start_study"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="开始学习"
            android:textSize="16sp"
            android:textAllCaps="false"
            app:cornerRadius="8dp" />

        <!-- 调整计划入口 -->
        <TextView
            android:id="@+id/tv_adjust_plan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="调整计划"
            android:textSize="14sp"
            android:textColor="?attr/colorPrimary"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:padding="8dp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>